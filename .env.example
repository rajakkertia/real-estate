# Resend — https://resend.com
# Required in production. If omitted in development, /api/send falls back
# to a console log and returns a mock success so the form stays usable.
RESEND_API_KEY=

# Optional: the verified sender address Resend should send from.
# If unset, the API falls back to the Resend sandbox sender.
# Example: "Atelier Estate <briefs@atelierestate.com>"
RESEND_FROM_EMAIL=

# Optional: inbox that should receive new briefs.
# Defaults to hello@atelierestate.com
LEAD_NOTIFICATION_EMAIL=
